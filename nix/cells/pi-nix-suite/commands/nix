#!/usr/bin/env bash
# /nix - Ask the Nix expert agent
# Usage: /nix <query>
#
# Spawns a Nix specialist agent to help with Nix expressions,
# flakes, or NixOS configuration.
#
# Example:
#   /nix "Debug this flake error"
#   /nix "How do I add a new system configuration?"

set -e

QUERY="$*"

if [[ -z "$QUERY" ]]; then
    echo "Usage: /nix <your Nix question>"
    exit 1
fi

TEMPLATE_DIR="${PI_NIX_SUITE_DIR:-$HOME/.pi/agent/templates}"
TEMPLATE_FILE="$TEMPLATE_DIR/agent-nix-expert.md"

# Generate agent name
AGENT_NAME="nix-expert-$(date +%s)"

# Create tmux window with Nix expert
tmux new-window -n "$AGENT_NAME" -c "$PWD" "
    export PI_SYSTEM_PROMPT_EXTRA=\"$(cat "$TEMPLATE_FILE")\"
    pi \"$QUERY\"
"

WINDOW_INDEX=$(tmux display-message -p '#I')
echo "Nix expert spawned in tmux window $WINDOW_INDEX"
echo "Press Ctrl+B then $WINDOW_INDEX to view"
