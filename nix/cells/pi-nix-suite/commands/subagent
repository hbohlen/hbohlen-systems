#!/usr/bin/env bash
# /subagent - Spawn a subagent in a new tmux window
# Usage: /subagent <task> [--agent=TYPE]
#
# Spawns a pi agent in a new tmux window. The agent type determines
# the system prompt and model used.
#
# Agent types:
#   scout      - Fast reconnaissance (claude-haiku)
#   worker     - Implementation agent (claude-sonnet)
#   nix-expert - Nix specialist (claude-sonnet)
#
# Example:
#   /subagent "Explore the codebase structure" --agent=scout
#   /subagent "Implement error handling in src/main.ts" --agent=worker

set -e

# Parse arguments
TASK="$1"
AGENT_TYPE="${2:-worker}"

# Load agent template
TEMPLATE_DIR="${PI_NIX_SUITE_DIR:-$HOME/.pi/agent/templates}"
TEMPLATE_FILE="$TEMPLATE_DIR/agent-$AGENT_TYPE.md"

if [[ ! -f "$TEMPLATE_FILE" ]]; then
    echo "Unknown agent type: $AGENT_TYPE"
    echo "Available types: scout, worker, nix-expert"
    exit 1
fi

# Generate agent name with timestamp
AGENT_NAME="${AGENT_TYPE}-$(date +%s)"

# Create tmux window with the agent
tmux new-window -n "$AGENT_NAME" -c "$PWD" "
    export PI_SYSTEM_PROMPT_EXTRA=\"$(cat "$TEMPLATE_FILE")\"
    pi \"$TASK\"
"

WINDOW_INDEX=$(tmux display-message -p '#I')
echo "Subagent spawned in tmux window $WINDOW_INDEX"
echo "Press Ctrl+B then $WINDOW_INDEX to view, Ctrl+B then 0 to return"
